# OpenRouter API key (required) — routes to Claude / Gemini / GPT with one key
OPENROUTER_API_KEY=sk-or-v1-...

# Model (optional) — defaults to anthropic/claude-haiku-4.5 (fast, reliable tool loops).
# Higher quality: anthropic/claude-sonnet-4.6
# Lowest cost: google/gemini-2.5-flash (less reliable in long tool loops)
# MODEL=anthropic/claude-haiku-4.5

# OpenRouteService key (optional) — enables cycling-network-aware routing with
# elevation via plan_route. Get a free key at https://openrouteservice.org/dev/#/signup
# If unset or invalid, plan_route automatically falls back to the keyless OSRM demo.
# ORS_API_KEY=...

# Self-hosted Overpass (optional, strongly recommended for speed) — point at a
# local instance with a Dutch OSM extract to remove the public rate limit and
# bring plans to ~15-35s. Falls back to the public endpoint if unset or
# unreachable. See README "Fast local Overpass" for the Docker command.
# OVERPASS_URL=http://localhost:12345/api/interpreter

# Intake extraction model (optional) — the tool-free entity-extraction call
# that gates planning (see backend/src/intake.ts). Defaults to MODEL, then Haiku 4.5.
# INTAKE_MODEL=anthropic/claude-haiku-4.5

# Vision model (optional) — used by the intake step ONLY when a photo is attached,
# to identify the start city/landmark (a small text model is weak at this). Defaults
# to google/gemini-2.5-flash; set anthropic/claude-sonnet-4.6 for best accuracy.
# VISION_MODEL=google/gemini-2.5-flash

# Server — binds to loopback by default (the agent is unauthenticated; binding
# 0.0.0.0 would let anyone on your network spend the API key).
# HOST=127.0.0.1
PORT=3000

# Speech-to-text backend (optional) — controls the 🎤 voice button.
#   browser  (default) — browser Web Speech API, no server call (mediocre accuracy)
#   gemini             — record in browser, transcribe via an audio-capable model
#                        through the SAME OpenRouter key (no new vendor). Domain-biased.
#   deepgram           — transcribe via Deepgram's STT API (needs DEEPGRAM_API_KEY)
# STT_BACKEND=browser
# STT_MODEL=google/gemini-2.5-flash   # gemini backend: any audio-capable OpenRouter model
# DEEPGRAM_API_KEY=...                 # required for STT_BACKEND=deepgram
# DEEPGRAM_MODEL=nova-2
# STT_LANGUAGE=en                      # optional locale hint (e.g. en, nl); auto-detect otherwise

# Feedback capture (optional, OFF by default) — point at a SQLite file to record
# anonymous thumbs up/down on delivered plans (with the tool trace that produced
# them) for the evaluation loop. Unset → no DB, no feedback controls in the UI.
# Uses Node's built-in node:sqlite (no extra dependency, needs Node 22.5+).
# Inspect with `make feedback-report`. See EVALUATION.md "Production feedback loop".
# FEEDBACK_DB=./feedback.db
